<h1>Products</h1>

<table>
    <thead>
    <tr>
        <th>Title</th>
        <th>Brand</th>
        <th>Price</th>
        <th>Category</th>
    </tr>
    </thead>

    <tbody>
    {% for product in products %}
        <tr>
            <td>
                <a href="/products/{{ product.id }}">
                    {{ product.title }}
                </a>
            </td>

            <td>{{ product.brand }}</td>
            <td>{{ product.price }}</td>
            <td>{{ product.category }}</td>
        </tr>
    {% endfor %}
    </tbody>
</table>