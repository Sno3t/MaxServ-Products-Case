{
  "name": "maxserv/opdracht-klas-2024",
  "description": "Docker & PHP opdracht voor de klas van 2024",
  "license": "GPL-2.0-or-later",
  "repositories": [
    {
      "type": "path",
      "url": "packages/*"
    }
  ],
  "autoload": {
    "psr-4": {
      "MaxServ\\Core\\": "packages/core/src/",
      "MaxServ\\App\\": "packages/app/src/"
    }
  },
  "require": {
    "php": "^8.2",
    "guzzlehttp/guzzle": "^7.0",
    "symfony/routing": "^7.2",
    "symfony/config": "^7.2",
    "symfony/yaml": "^7.2",
    "symfony/http-foundation": "^7.2",
    "symfony/dependency-injection": "^7.2",
    "symfony/finder": "^7.2",
    "ext-pdo": "*",
    "twig/twig": "^3.0",
    "maxserv/app": "*",
    "maxserv/core": "*"
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
